<Window x:Class="BulkDDSConverter.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Bulk DDS Converter" Height="520" Width="720" ResizeMode="CanMinimize" Background="#0A0F1A" Foreground="#E5E7EB" FontFamily="Segoe UI" FontSize="12" AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

    <Window.Resources>
        <SolidColorBrush x:Key="BgPrimary" Color="#0A0F1A"/>
        <SolidColorBrush x:Key="PanelBg" Color="#0B1220"/>
        <SolidColorBrush x:Key="InputBg" Color="#050912"/>
        <SolidColorBrush x:Key="BorderColor" Color="#1A2A44"/>
        <SolidColorBrush x:Key="Accent" Color="#4F8CFF"/>
        <SolidColorBrush x:Key="AccentDark" Color="#2F6BFF"/>
        <Thickness x:Key="SectionMargin">0,0,0,10</Thickness>
        <Thickness x:Key="ControlPadding">8,6</Thickness>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource InputBg}"/>
            <Setter Property="Foreground" Value="{StaticResource Accent}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="{StaticResource ControlPadding}"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background"
                    Value="#050912"/>
            <Setter Property="Foreground"
                    Value="#E5E7EB"/>
            <Setter Property="BorderBrush"
                    Value="#1A2A44"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="6"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>

                            <!-- MAIN BORDER -->
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">

                                <Grid>

                                    <!-- Selected text -->
                                    <ContentPresenter Margin="8,2,28,2"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>

                                    <!-- ARROW ICON -->
                                    <Path x:Name="Arrow"
                                          Data="M 0 0 L 4 4 L 8 0 Z"
                                          Fill="#94A3B8"
                                          Width="10"
                                          Height="6"
                                          HorizontalAlignment="Right"
                                          Margin="0,0,10,0"
                                          VerticalAlignment="Center"/>

                                    <!-- CLICK AREA -->
                                    <ToggleButton x:Name="ToggleButton"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"/>

                                </Grid>
                            </Border>

                            <!-- DROPDOWN -->
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   Focusable="False">

                                <Border Background="#050912"
                                        BorderBrush="#1A2A44"
                                        BorderThickness="1">

                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>

                                </Border>
                            </Popup>

                        </Grid>

                        <!-- HOVER + STATE ANIMATION -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver"
                                    Value="True">
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#4F8CFF"/>
                                <Setter TargetName="Arrow"
                                        Property="Fill"
                                        Value="#4F8CFF"/>
                            </Trigger>

                            <!-- Open state -->
                            <Trigger Property="IsDropDownOpen"
                                    Value="True">
                                <Setter TargetName="Arrow"
                                        Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180"
                                                CenterX="5"
                                                CenterY="3"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="MainBorder"
                                        Property="BorderBrush"
                                        Value="#4F8CFF"/>
                            </Trigger>

                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#050912"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#4F8CFF"/>
                    <Setter Property="Foreground" Value="#020617"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="14" Height="14" Background="#050912" BorderBrush="#1A2A44" BorderThickness="1"/>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4F8CFF"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4F8CFF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4F8CFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="6"/>
            <Setter Property="Background" Value="#050912"/>
            <Setter Property="Foreground" Value="#4F8CFF"/>
            <Setter Property="BorderBrush" Value="#1A2A44"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Rectangle x:Name="PART_Track"  Fill="#050912"/>
                                <Rectangle x:Name="PART_Indicator" HorizontalAlignment="Left" Fill="{TemplateBinding Foreground}" Width="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="True">
                                <Setter TargetName="PART_Indicator" Property="Width" Value="Auto"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#14233A" BorderThickness="1" Padding="12" Margin="16">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="SYSTEM_LINK" Foreground="{StaticResource Accent}" FontSize="10" Opacity="0.6"/>
                <TextBlock Text="BULK DDS CONVERTER" FontSize="24" FontWeight="SemiBold"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="{StaticResource SectionMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="FolderBox" IsReadOnly="True" Text="Select a root folder..."/>
                <Button Grid.Column="1" Content="BROWSE..." Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="Browse_Click"/>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource SectionMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="FORMAT:" VerticalAlignment="Center" Foreground="#94A3B8" Margin="0,0,10,0"/>
                <ComboBox x:Name="FormatSelector" Grid.Column="1">
                    <ComboBoxItem Content="BC1 — Opaque"/>
                    <ComboBoxItem Content="BC3 — Alpha"/>
                    <ComboBoxItem Content="BC5 — Normals"/>
                    <ComboBoxItem Content="BC7 — High Quality"/>
                </ComboBox>
                <CheckBox x:Name="GpuToggle" Grid.Column="2" Content="GPU" Margin="10,0,0,0"/>
            </Grid>

            <StackPanel Grid.Row="3" Orientation="Horizontal">
                <Button x:Name="ConvertBtn" Content="INITIALIZE CONVERSION" Style="{StaticResource PrimaryButton}" Background="{StaticResource Accent}" Foreground="#020617" Click="ConvertBtn_Click"/>
                <Button x:Name="CancelBtn" Content="ABORT" Style="{StaticResource PrimaryButton}" Foreground="#EF4444" Margin="10,0,0,0" Visibility="Collapsed" Click="CancelBtn_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock x:Name="FileCountLabel" Text="FILES: 0" Foreground="#A3B1C6" FontFamily="Consolas"/>
                <TextBlock x:Name="SpeedLabel" Text="0.0 files/sec" Foreground="#A3B1C6" FontFamily="Consolas"/>
            </StackPanel>

            <StackPanel Grid.Row="5">
                <ProgressBar x:Name="ProgressBar"/>
                <TextBlock x:Name="StatusLabel" Text="SYSTEM READY" Foreground="{StaticResource Accent}" FontFamily="Consolas"/>
                <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <Grid x:Name="DropOverlay" Background="#AA000000" Visibility="Collapsed" IsHitTestVisible="False">
                <TextBlock Text="DROP HERE" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="24" Foreground="{StaticResource Accent}"/>
            </Grid>

        </Grid>
    </Border>
</Window>